# Private documents — never committed
# This includes: bus-factor continuator identities, dead-man switch
# configurations, credentials, and other sensitive operational details
# that are part of the initiative's operations but not suitable for
# public disclosure per the threat model.
#
# Public references to the existence of these documents are allowed
# (and expected) in the public governance/architecture docs — but the
# documents themselves stay local.

private/
*.private.md

# Secrets — should never be committed but extra belt-and-suspenders
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
*_rsa
*_rsa.pub
secrets/
credentials/

# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db

# Node (for future code)
node_modules/
dist/
build/
.next/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Python (for future code)
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/

# Temporary
tmp/
temp/
*.tmp
